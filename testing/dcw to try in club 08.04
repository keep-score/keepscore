# =========================
# HELPERS
# =========================

def log(msg):
    print(f"[dcw] {msg}", flush=True)

def now_ms():
    return int(time.time() * 1000)

def safe_int(value, default):
    try:
        return int(value)
    except Exception:
        return default

def http_get_json(url, timeout=4):
    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=timeout) as response:
        raw = response.read().decode("utf-8", errors="replace")
        return json.loads(raw)

def http_get_text(url, timeout=4):
    req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
    with urllib.request.urlopen(req, timeout=timeout) as response:
        return response.read().decode("utf-8", errors="replace")

def fetch_latest_dweet():
    data = http_get_json(f"{DWEET_GET_URL}?t={now_ms()}", timeout=HTTP_TIMEOUT_DWEET)
    items = data.get("with", [])
    if not items:
        return None
    return items[0].get("content", {})

def fetch_latest_hdmi_dweet():
    data = http_get_json(f"{DWEET_HDMI_GET_URL}?t={now_ms()}", timeout=HTTP_TIMEOUT_DWEET)
    items = data.get("with", [])
    if not items:
        return None
    return items[0].get("content", {})

def push_camera_status(online):
    params = urllib.parse.urlencode({
        "online": "1" if online else "0",
        "ts": str(now_ms())
    })
    url = f"{DWEET_CAMERA_SET_BASE}?{params}"
    raw = http_get_text(url, timeout=HTTP_TIMEOUT_DWEET)
    log(f"Camera status pushed: {'online' if online else 'offline'}")
    return raw

def dweet_reset_state(player1="", player2="", match_title_enabled="0", match_title=DEFAULT_MATCH_INFO):
    player1 = clean_single_line(player1)
    player2 = clean_single_line(player2)
    match_title = clean_single_line(match_title) or DEFAULT_MATCH_INFO
    match_title_enabled = "1" if str(match_title_enabled) == "1" else "0"

    params = urllib.parse.urlencode({
        "player1": player1,
        "player2": player2,
        "score1": "0",
        "score2": "0",
        "display": "",
        "visible": "0",
        "breaker": "1",
        "auto_reset_cancel": "0",
        "match_info_enabled": match_title_enabled,
        "match_info": match_title,
        "match_title_enabled": match_title_enabled,
        "match_title": match_title,
        "ts": str(now_ms())
    })
    url = f"{DWEET_SET_BASE}?{params}"
    http_get_text(url, timeout=HTTP_TIMEOUT_DWEET)
    log("Dweet state reset to start screen state.")

def build_camera_query(params):
    return urllib.parse.urlencode(params, doseq=True, safe="[]", quote_via=urllib.parse.quote)

def clean_single_line(text):
    text = str(text or "")
    text = text.replace("\r\n", " ").replace("\r", " ").replace("\n", " ").replace("|", " ")
    text = re.sub(r"\s+", " ", text).strip()
    return text

def clean_for_dahua(text):
    text = str(text or "")
    text = text.replace("\r\n", " ")
    text = text.replace("\r", " ")
    text = text.replace("\n", " ")
    text = text.replace("|", " ")
    text = text.replace("'", " ")
    text = text.replace("’", " ")
    return text

def score_to_text(value):
    try:
        return str(int(value))
    except Exception:
        return "0"

def get_first_nonempty(content, keys, default=""):
    for key in keys:
        val = content.get(key)
        if val is not None and str(val) != "":
            return val
    return default

def parse_scores_from_display(display):
    text = str(display or "")
    m = re.search(r"(\d+)\s*[-:]\s*(\d+)", text)
    if m:
        return m.group(1), m.group(2)

    nums = re.findall(r"\d+", text)
    if len(nums) >= 2:
        return nums[0], nums[1]

    return "0", "0"

def build_player_line(score, player_name, breaker_for_this_line):
    try:
        score_num = int(score)
    except Exception:
        score_num = 0

    score_text = str(score_num)
    player_name = clean_for_dahua(player_name)

    if score_num <= 9:
        score_text = "  " + score_text

    line = f"{score_text}  {player_name}".rstrip()

    if breaker_for_this_line:
        line = f"{line} •".rstrip()

    return line if line.strip() else "."

def weighted_name_length_for_box(text):
    text = clean_for_dahua(text).upper()

    total = 0.0
    for ch in text:
        if ch == ".":
            total += 0.5
        elif ch == "I":
            total += 0.5
        elif ch == " ":
            total += 0.6
        else:
            total += 1.0

    return total

def compute_name_box_right(player1_name, player2_name):
    p1_weight = weighted_name_length_for_box(player1_name)
    p2_weight = weighted_name_length_for_box(player2_name)

    longest_weight = max(p1_weight, p2_weight)
    effective_len = longest_weight + 1.0

    right = NAME_BOX_LEFT + int(effective_len * NAME_BOX_PER_CHAR) + NAME_BOX_EXTRA

    if right < NAME_BOX_MIN_RIGHT:
        right = NAME_BOX_MIN_RIGHT
    if right > NAME_BOX_MAX_RIGHT:
        right = NAME_BOX_MAX_RIGHT

    return right

def get_name_box_rects(player1_name, player2_name):
    right = compute_name_box_right(player1_name, player2_name)
    p1_rect = (NAME_BOX_LEFT, 110, right, 450)
    p2_rect = (NAME_BOX_LEFT, 560, right, 900)
    return p1_rect, p2_rect

def normalize_match_text(text):
    text = str(text or "")
    text = unicodedata.normalize("NFD", text)
    text = "".join(ch for ch in text if unicodedata.category(ch) != "Mn")
    return text.lower().strip()

def parse_match_target(match_info):
    text = normalize_match_text(match_info)

    patterns = [
        r"\bpremier\s+a\s+(\d{1,3})\b",
        r"\bpremiere?\s+a\s+(\d{1,3})\b",
        r"\bfirst\s+to\s+(\d{1,3})\b",
        r"\brace\s+to\s+(\d{1,3})\b",
        r"\bcourse\s+a\s+(\d{1,3})\b",
    ]

    for pattern in patterns:
        m = re.search(pattern, text, flags=re.IGNORECASE)
        if m:
            try:
                value = int(m.group(1))
                if value > 0:
                    return value
            except Exception:
                pass

    return None

def get_winner_info(score1, score2, match_info, player1, player2):
    try:
        s1 = int(score1)
    except Exception:
        s1 = 0

    try:
        s2 = int(score2)
    except Exception:
        s2 = 0

    target = parse_match_target(match_info)
    if not target:
        return None

    if s1 < target and s2 < target:
        return None

    if s1 == s2:
        return None

    if s1 >= target and s1 > s2:
        return {
            "winner_num": 1,
            "winner_name": player1 or "JOUEUR 1",
            "target": target,
            "score1": s1,
            "score2": s2
        }

    if s2 >= target and s2 > s1:
        return {
            "winner_num": 2,
            "winner_name": player2 or "JOUEUR 2",
            "target": target,
            "score1": s1,
            "score2": s2
        }

    return None

# =========================
# CAMERA COMMANDS
# =========================

def camera_request(params):
    query = build_camera_query(params)
    url = f"{CAMERA_BASE}?{query}"
    try:
        with camera_opener.open(url, timeout=HTTP_TIMEOUT_CAMERA) as response:
            return response.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as e:
        try:
            body = e.read().decode("utf-8", errors="replace")
        except Exception:
            body = ""
        log(f"Camera HTTP error {e.code}: {body}")
        return ""
    except Exception as e:
        log(f"Camera request error: {e}")
        return ""

def camera_is_online():
    raw = camera_request({
        "action": "getConfig",
        "name": "ChannelTitle[0].Name"
    })

    if not raw or not raw.strip():
        return False

    low = raw.lower()
    if "unauthorized" in low:
        return False

    return True

def camera_set_config(params, label):
    query = build_camera_query(params)
    url = f"{CAMERA_BASE}?{query}"

    try:
        with camera_opener.open(url, timeout=HTTP_TIMEOUT_CAMERA) as response:
            raw = response.read().decode("utf-8", errors="replace")
            log(f"{label} response: {raw.strip()}")
            return SUCCESS_TEXT in raw
    except urllib.error.HTTPError as e:
        try:
            body = e.read().decode("utf-8", errors="replace")
        except Exception:
            body = ""
        log(f"{label} HTTP error {e.code}: {body}")
        return False
    except Exception as e:
        log(f"{label} error: {e}")
        return False

def set_channel_title_line(text, visible):
    visible_str = "true" if str(visible) == "1" else "false"
    text_to_send = clean_for_dahua(text) if (str(visible) == "1" and str(text).strip()) else "."

    left, top, right, bottom = PLAYER1_TEXT_RECT

    params = [
        ("action", "setConfig"),
        ("ChannelTitle[0].Name", text_to_send),
        ("VideoWidget[0].ChannelTitle.EncodeBlend", visible_str),
        ("VideoWidget[0].ChannelTitle.PreviewBlend", visible_str),
        ("VideoWidget[0].ChannelTitle.Rect[0]", str(left)),
        ("VideoWidget[0].ChannelTitle.Rect[1]", str(top)),
        ("VideoWidget[0].ChannelTitle.Rect[2]", str(right)),
        ("VideoWidget[0].ChannelTitle.Rect[3]", str(bottom)),
    ]
    return camera_set_config(params, "Player 1 line")

