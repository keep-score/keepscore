def set_cover_box(index, rect, color, enabled):
    visible_str = "true" if str(enabled) == "1" else "false"
    base = f"VideoWidget[0].Covers[{index}]"

    left, top, right, bottom = rect
    r, g, b, a = color

    params = [
        ("action", "setConfig"),
        (f"{base}.EncodeBlend", visible_str),
        (f"{base}.PreviewBlend", visible_str),
        (f"{base}.BackColor[0]", str(r)),
        (f"{base}.BackColor[1]", str(g)),
        (f"{base}.BackColor[2]", str(b)),
        (f"{base}.BackColor[3]", str(a)),
        (f"{base}.FrontColor[0]", str(r)),
        (f"{base}.FrontColor[1]", str(g)),
        (f"{base}.FrontColor[2]", str(b)),
        (f"{base}.FrontColor[3]", "0"),
        (f"{base}.Rect[0]", str(left)),
        (f"{base}.Rect[1]", str(top)),
        (f"{base}.Rect[2]", str(right)),
        (f"{base}.Rect[3]", str(bottom)),
    ]
    return camera_set_config(params, f"Cover box {index}")

def show_name_box(index, rect):
    return set_cover_box(index, rect, PLAYER_NAME_BOX_COLOR, 1)

def hide_name_box(index, rect):
    return set_cover_box(index, rect, PLAYER_NAME_BOX_COLOR, 0)

def clear_overlay(player1_name="", player2_name=""):
    rect1, rect2 = get_name_box_rects(player1_name, player2_name)

    ok_info = hide_match_info()
    ok_p2 = hide_player2_line()
    ok_black2 = hide_name_box(PLAYER2_NAME_BOX_INDEX, rect2)
    ok_blue = set_cover_box(PLAYER2_BOX_INDEX, PLAYER2_BOX_RECT, PLAYER2_BOX_COLOR, 0)
    ok_p1 = hide_channel_title_line()
    ok_black1 = hide_name_box(PLAYER1_NAME_BOX_INDEX, rect1)
    ok_red = set_cover_box(PLAYER1_BOX_INDEX, PLAYER1_BOX_RECT, PLAYER1_BOX_COLOR, 0)

    return ok_info and ok_p2 and ok_black2 and ok_blue and ok_p1 and ok_black1 and ok_red

# =========================
# HDMI SUBSTREAM CONTROL
# =========================

def hdmi_process_alive():
    global hdmi_process
    return hdmi_process is not None and hdmi_process.poll() is None

def hdmi_power_on():
    try:
        subprocess.call(
            ["tvservice", "-p"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        time.sleep(1.0)
    except Exception as e:
        log(f"HDMI power on error: {e}")

def hdmi_power_off():
    try:
        subprocess.call(
            ["tvservice", "-o"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
    except Exception as e:
        log(f"HDMI power off error: {e}")

def start_hdmi_substream():
    global hdmi_process

    if hdmi_process_alive():
        log("HDMI substream already running.")
        return

    try:
        hdmi_power_on()
        hdmi_process = subprocess.Popen(
            HDMI_START_CMD,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        log("HDMI substream started.")
    except Exception as e:
        hdmi_process = None
        log(f"Failed to start HDMI substream: {e}")

def stop_hdmi_substream():
    global hdmi_process

    if hdmi_process_alive():
        try:
            hdmi_process.terminate()
            try:
                hdmi_process.wait(timeout=3)
            except Exception:
                hdmi_process.kill()
                hdmi_process.wait(timeout=2)
        except Exception as e:
            log(f"Tracked omxplayer stop issue: {e}")

    try:
        subprocess.call(
            ["killall", "-q", "omxplayer.bin"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
    except Exception:
        pass

    try:
        subprocess.call(
            ["killall", "-q", "omxplayer"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
    except Exception:
        pass

    hdmi_process = None
    time.sleep(0.5)
    hdmi_power_off()
    log("HDMI substream stopped.")

def process_latest_hdmi_dweet():
    global last_hdmi_signature, hdmi_process

    latest = fetch_latest_hdmi_dweet()
    if not latest:
        return

    hdmi_value = str(latest.get("hdmi", "0"))
    ts = safe_int(latest.get("ts"), 0)
    signature = f"{hdmi_value}|{ts}"

    if signature == last_hdmi_signature:
        if hdmi_process is not None and not hdmi_process_alive():
            log("HDMI player exited unexpectedly.")
            hdmi_process = None
            if hdmi_value == "0":
                hdmi_power_off()
        return

    last_hdmi_signature = signature

    if hdmi_value == "1":
        start_hdmi_substream()
    else:
        stop_hdmi_substream()

# =========================
# AUTO RESET LOGIC
# =========================

def clear_pending_auto_reset():
    global pending_auto_reset_deadline_ms, pending_auto_reset_key, pending_auto_reset_cancelled
    pending_auto_reset_deadline_ms = None
    pending_auto_reset_key = None
    pending_auto_reset_cancelled = False

def auto_reset_check():
    global last_seen_signature, last_visible_value, last_seen_ts

    if pending_auto_reset_deadline_ms is None:
        return

    if pending_auto_reset_cancelled:
        return

    if now_ms() < pending_auto_reset_deadline_ms:
        return

    log("Winner countdown elapsed. Auto-clearing overlay.")
    clear_overlay("", "")

    latest = fetch_latest_dweet() or {}

    reset_player1 = clean_single_line(get_first_nonempty(latest, ["player1", "name1"], ""))
    reset_player2 = clean_single_line(get_first_nonempty(latest, ["player2", "name2"], ""))
    reset_match_title_enabled = str(
        get_first_nonempty(latest, ["match_info_enabled", "match_title_enabled"], "0")
    )
    reset_match_title = clean_single_line(
        get_first_nonempty(latest, ["match_info", "match_title"], DEFAULT_MATCH_INFO)
    )

    dweet_reset_state(
        player1=reset_player1,
        player2=reset_player2,
        match_title_enabled=reset_match_title_enabled,
        match_title=reset_match_title
    )

    last_seen_signature = None
    last_visible_value = "0"
    last_seen_ts = now_ms()
    clear_pending_auto_reset()

# =========================
# DWEET PROCESSING
# =========================

def process_latest_dweet():
    global last_seen_ts, last_seen_signature, last_visible_value
    global pending_auto_reset_deadline_ms, pending_auto_reset_key, pending_auto_reset_cancelled

    latest = fetch_latest_dweet()
    if not latest:
        log("No dweet received.")
        return

    visible = str(latest.get("visible", "1"))
    breaker = str(latest.get("breaker", "1")).strip()
    auto_reset_cancel = str(latest.get("auto_reset_cancel", "0")).strip()

    player1 = clean_single_line(get_first_nonempty(latest, ["player1", "name1"], ""))
    player2 = clean_single_line(get_first_nonempty(latest, ["player2", "name2"], ""))

    score1_raw = get_first_nonempty(latest, ["score1", "p1score", "player1score"], "")
    score2_raw = get_first_nonempty(latest, ["score2", "p2score", "player2score"], "")

    display = str(latest.get("display", ""))

    if score1_raw == "" or score2_raw == "":
        parsed1, parsed2 = parse_scores_from_display(display)
        if score1_raw == "":
            score1_raw = parsed1
        if score2_raw == "":
            score2_raw = parsed2

    score1 = score_to_text(score1_raw)
    score2 = score_to_text(score2_raw)

    match_info_enabled = str(
        get_first_nonempty(latest, ["match_info_enabled", "match_title_enabled"], "0")
    )
    match_info = clean_single_line(
        get_first_nonempty(latest, ["match_info", "match_title"], DEFAULT_MATCH_INFO)
    )

    ts = safe_int(latest.get("ts"), 0)

    player1_plain = build_player_line(score1, player1, False)
    player2_plain = build_player_line(score2, player2, False)
    player1_break = build_player_line(score1, player1, breaker == "1")
    player2_break = build_player_line(score2, player2, breaker == "2")

    if breaker == "1":
        player1_final = player1_break
        player2_final = player2_plain
    elif breaker == "2":
        player1_final = player1_plain
        player2_final = player2_break
    else:
        player1_final = player1_plain
        player2_final = player2_plain

    name_box_rect1, name_box_rect2 = get_name_box_rects(player1, player2)

    signature = (
        f"{visible}|{breaker}|{auto_reset_cancel}|"
        f"{player1}|{player2}|{score1}|{score2}|"
        f"{match_info_enabled}|{match_info}|{ts}"
    )

    if ts > 0:
        last_seen_ts = ts

    winner_info = None
    winner_key = None

    if visible == "1" and match_info_enabled == "1":
        winner_info = get_winner_info(score1, score2, match_info, player1, player2)

    if winner_info:
        winner_key = (
            f"{winner_info['winner_num']}|{winner_info['target']}|"
            f"{winner_info['score1']}|{winner_info['score2']}|"
            f"{player1}|{player2}|{match_info}"
        )

        if auto_reset_cancel == "1":
            if pending_auto_reset_key != winner_key:
                pending_auto_reset_key = winner_key
                pending_auto_reset_deadline_ms = None
            pending_auto_reset_cancelled = True
            log("Auto reset cancelled by website.")
        else:
            if pending_auto_reset_key != winner_key or pending_auto_reset_deadline_ms is None:
                pending_auto_reset_key = winner_key
                pending_auto_reset_deadline_ms = now_ms() + (AUTO_RESET_SECONDS * 1000)
                pending_auto_reset_cancelled = False
                log(
                    f"Winner detected: {winner_info['winner_name']} "
                    f"(target {winner_info['target']}) - auto reset in {AUTO_RESET_SECONDS}s."
                )
    else:
        clear_pending_auto_reset()

    if signature == last_seen_signature:
        return

    was_visible = (last_visible_value == "1")
    now_visible = (visible == "1")

    last_seen_signature = signature
    last_visible_value = visible

    if now_visible and not was_visible:
        ok_prep1 = prepare_channel_title_line(player1_final)
        ok_prep2 = prepare_player2_line(player2_final)

        if match_info_enabled == "1" and match_info.strip():
            ok_prep_info = prepare_match_info(match_info)
        else:
            ok_prep_info = hide_match_info()

        p1_has_name = bool(player1)
        p2_has_name = bool(player2)

        ok_red = set_cover_box(PLAYER1_BOX_INDEX, PLAYER1_BOX_RECT, PLAYER1_BOX_COLOR, 1)

        if p1_has_name:
            ok_black1 = show_name_box(PLAYER1_NAME_BOX_INDEX, name_box_rect1)
        else:
            ok_black1 = hide_name_box(PLAYER1_NAME_BOX_INDEX, name_box_rect1)

        ok_p1 = show_channel_title_line()

        ok_blue = set_cover_box(PLAYER2_BOX_INDEX, PLAYER2_BOX_RECT, PLAYER2_BOX_COLOR, 1)

        if p2_has_name:
            ok_black2 = show_name_box(PLAYER2_NAME_BOX_INDEX, name_box_rect2)
        else:
            ok_black2 = hide_name_box(PLAYER2_NAME_BOX_INDEX, name_box_rect2)

        ok_p2 = show_player2_line()

        if match_info_enabled == "1" and match_info.strip():
            ok_info = show_match_info()
        else:
            ok_info = True

        if ok_prep1 and ok_prep2 and ok_prep_info and ok_red and ok_black1 and ok_p1 and ok_blue and ok_black2 and ok_p2 and ok_info:
            log(f"Scoreboard shown: {player1_final} / {player2_final} / {match_info}")
        else:
            log("Failed to show one or more scoreboard elements.")

    elif (not now_visible) and was_visible:
        clear_pending_auto_reset()

        if clear_overlay(player1, player2):
            log("Scoreboard hidden.")
        else:
            log("Failed to hide one or more scoreboard elements.")

    elif now_visible:
        p1_has_name = bool(player1)
        p2_has_name = bool(player2)

        if p1_has_name:
            ok_black1 = show_name_box(PLAYER1_NAME_BOX_INDEX, name_box_rect1)
        else:
            ok_black1 = hide_name_box(PLAYER1_NAME_BOX_INDEX, name_box_rect1)

        if p2_has_name:
            ok_black2 = show_name_box(PLAYER2_NAME_BOX_INDEX, name_box_rect2)
        else:
            ok_black2 = hide_name_box(PLAYER2_NAME_BOX_INDEX, name_box_rect2)

        if breaker == "1":
            ok_p2 = set_player2_line(player2_plain, 1)
            ok_p1 = set_channel_title_line(player1_break, 1)
        elif breaker == "2":
            ok_p1 = set_channel_title_line(player1_plain, 1)
            ok_p2 = set_player2_line(player2_break, 1)
        else:
            ok_p1 = set_channel_title_line(player1_plain, 1)
            ok_p2 = set_player2_line(player2_plain, 1)

        ok_red = set_cover_box(PLAYER1_BOX_INDEX, PLAYER1_BOX_RECT, PLAYER1_BOX_COLOR, 1)
        ok_blue = set_cover_box(PLAYER2_BOX_INDEX, PLAYER2_BOX_RECT, PLAYER2_BOX_COLOR, 1)

        if match_info_enabled == "1" and match_info.strip():
            ok_info = set_match_info(match_info, 1)
        else:
            ok_info = hide_match_info()

        if ok_black1 and ok_black2 and ok_p1 and ok_p2 and ok_red and ok_blue and ok_info:
            log(f"Scoreboard updated: {player1_final} / {player2_final} / {match_info}")
        else:
            log("Failed to update one or more scoreboard elements.")

    else:
        clear_pending_auto_reset()

        if clear_overlay(player1, player2):
            log("Scoreboard remains hidden.")
        else:
            log("Failed to maintain hidden scoreboard state.")

def idle_check():
    global last_seen_signature, last_visible_value, last_seen_ts

    if last_seen_ts <= 0:
        return

    age_seconds = (now_ms() - last_seen_ts) / 1000.0
    if age_seconds < IDLE_RESET_SECONDS:
        return

    log("Inactivity detected. Auto-clearing overlay.")
    clear_overlay("", "")

    latest = fetch_latest_dweet() or {}

    reset_player1 = clean_single_line(get_first_nonempty(latest, ["player1", "name1"], ""))
    reset_player2 = clean_single_line(get_first_nonempty(latest, ["player2", "name2"], ""))
    reset_match_title_enabled = str(
        get_first_nonempty(latest, ["match_info_enabled", "match_title_enabled"], "0")
    )
    reset_match_title = clean_single_line(
        get_first_nonempty(latest, ["match_info", "match_title"], DEFAULT_MATCH_INFO)
    )

    dweet_reset_state(
        player1=reset_player1,
        player2=reset_player2,
        match_title_enabled=reset_match_title_enabled,
        match_title=reset_match_title
    )

    last_seen_signature = None
    last_visible_value = "0"
    last_seen_ts = now_ms()
    clear_pending_auto_reset()

# =========================
# MAIN LOOP
# =========================

def main():
    global last_camera_status_push_at, last_dweet_poll_at, last_hdmi_poll_at, last_visible_value

    log("Starting headless scoreboard controller.")

    try:
        if clear_overlay("", ""):
            log("Startup overlay clear complete.")
        else:
            log("Startup overlay clear had one or more failures.")
    except Exception as e:
        log(f"Startup overlay clear error: {e}")

    last_visible_value = "0"

    try:
        stop_hdmi_substream()
    except Exception as e:
        log(f"Startup stop HDMI error: {e}")

    while True:
        loop_started = time.time()

        try:
            if loop_started - last_camera_status_push_at >= CAMERA_STATUS_SECONDS:
                online = camera_is_online()
                push_camera_status(online)
                last_camera_status_push_at = loop_started
        except Exception as e:
            log(f"Camera status section error: {e}")

        try:
            if loop_started - last_dweet_poll_at >= POLL_SECONDS:
                process_latest_dweet()
                last_dweet_poll_at = loop_started
        except Exception as e:
            log(f"Dweet processing section error: {e}")

        try:
            if loop_started - last_hdmi_poll_at >= HDMI_POLL_SECONDS:
                process_latest_hdmi_dweet()
                last_hdmi_poll_at = loop_started
        except Exception as e:
            log(f"HDMI section error: {e}")

        try:
            auto_reset_check()
        except Exception as e:
            log(f"Auto reset section error: {e}")

        try:
            idle_check()
        except Exception as e:
            log(f"Idle check section error: {e}")

        time.sleep(0.2)

if __name__ == "__main__":
    try:
        main()
    finally:
        try:
            stop_hdmi_substream()
        except Exception:
            pass
